   "source": [
    "## randomly generate\n",
    "## (4n)/N\n",
    "## if x^2+y^2 <=1\n",
    "\n",
    "import random\n",
    "\n",
    "points = {}\n",
    "n = 0\n",
    "total =1000000\n",
    "for i in range(0,total+1):\n",
    "    x = 2*random.random()-1\n",
    "    y= 2*random.random()-1\n",
    "\n",
    "    points[x]=y\n",
    "\n",
    "    if x**2+y**2<=1:\n",
    "        n+=1\n",
    "\n",
    "\n",
    "print((4*n)/total)\n",
    "\n"
   ]
  }
 ],
